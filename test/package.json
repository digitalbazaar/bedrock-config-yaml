{
  "name": "bedrock-config-yaml-test",
  "version": "0.0.1-0",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "node --preserve-symlinks test.js test",
    "coverage": "cross-env NODE_ENV=test c8 --reporter=lcov --reporter=text-summary npm test",
    "coverage-ci": "cross-env NODE_ENV=test c8 --reporter=lcovonly npm test",
    "coverage-report": "c8 report"
  },
  "dependencies": {
    "@bedrock/config-yaml": "file:..",
    "@bedrock/core": "^6.3.0",
    "@bedrock/test": "^9.0.0",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "cross-env": "^10.1.0",
    "sinon": "^22.0.0",
    "winston": "^3.19.0"
  },
  "c8": {
    "excludeNodeModules": false,
    "include": [
      "node_modules/@bedrock/config-yaml/**"
    ],
    "exclude": [
      "node_modules/@bedrock/config-yaml/node_modules/**"
    ]
  }
}
